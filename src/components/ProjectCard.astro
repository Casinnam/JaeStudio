---
import type { Project } from '../data/site';
import { formatWon } from '../data/site';

interface Props { project: Project; featured?: boolean; }
const { project, featured = false } = Astro.props;
const projectIndex = ['focus-flow', 'insight-board', 'simple-sell', 'nomad-kit'].indexOf(project.slug) + 1;
---

<article class:list={["project-card", featured && "project-card-featured"]}>
  <a class="project-visual" href={`/projects/${project.slug}`} style={`--accent:${project.accent}`}>
    <div class="mini-window">
      <span></span><span></span><span></span>
    </div>
    <div class="visual-grid"></div>
    <span class="project-index">{String(projectIndex).padStart(2, '0')}</span>
    <strong>{project.name}</strong>
    <small>{project.year} DIGITAL PRODUCT</small>
  </a>
  <div class="project-card-body">
    <div class="project-title-row">
      <div>
        <span class:list={["status", `status-${project.status.replace(' ', '-')}`]}>{project.status}</span>
        <h3><a href={`/projects/${project.slug}`}>{project.name}</a></h3>
      </div>
      <a class="round-link" href={`/projects/${project.slug}`} aria-label={`${project.name} 자세히 보기`}>↗</a>
    </div>
    <p>{project.description}</p>
    <div class="project-facts">
      <span><b>{project.durationDays}</b>일</span>
      <span><b>{project.aiTools.length}</b> AI</span>
      <span><b>{formatWon(project.marketingCost)}</b> 마케팅</span>
    </div>
  </div>
</article>
