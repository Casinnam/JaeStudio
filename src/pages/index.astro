---
import BaseLayout from '../layouts/BaseLayout.astro';
import OceanScene from '../components/OceanScene.astro';

const yearData = [
  { year: '2023', count: 2 },
  { year: '2024', count: 5 },
  { year: '2025', count: 8 },
  { year: '2026', count: null }
];
---

<BaseLayout>
  <section class="hero shell">
    <div class="hero-copy">
      <span class="eyebrow">INDEPENDENT MAKER · BUILDING IN PUBLIC</span>
      <h1>아이디어를<br /><em>수익이 나는</em><br />서비스로.</h1>
      <p>혼자 만들고, 빠르게 출시하고, 결과를 숨김없이 기록합니다. 목표는 단순합니다. 어디서든 일할 수 있는 삶.</p>
      <div class="hero-actions">
        <a class="button button-primary" href="/projects">프로젝트 둘러보기 <span>↗</span></a>
        <a class="text-link" href="#numbers">숫자로 보는 Jae <span>↓</span></a>
      </div>
    </div>
    <OceanScene />
  </section>

  <section class="ticker" aria-label="제작 원칙">
    <div>
      <span>SHIP SMALL</span><b>✦</b><span>REVENUE FIRST</span><b>✦</b><span>STAY CURIOUS</span><b>✦</b><span>BUILD ANYWHERE</span><b>✦</b><span>SHIP SMALL</span>
    </div>
  </section>

  <section class="section shell" id="numbers">
    <div class="section-heading split-heading">
      <div>
        <span class="eyebrow">THE NUMBERS</span>
        <h2>감이 아니라<br />숫자로 말합니다.</h2>
      </div>
      <p>좋아요보다 결제, 다운로드보다 재사용. 모든 프로젝트의 실제 결과를 기록합니다.</p>
    </div>
    <div class="metrics-grid">
      <article class="metric-card metric-dark">
        <span>누적 매출</span>
        <strong data-live-revenue>—</strong>
        <small>공개 프로젝트 기준</small>
      </article>
      <article class="metric-card">
        <span>올해 프로젝트</span>
        <strong data-live-projects>—</strong>
        <small>목표 12개 중</small>
      </article>
      <article class="metric-card">
        <span>평균 제작 기간</span>
        <strong><span data-live-days>—</span><i>일</i></strong>
        <small>아이디어 → 출시</small>
      </article>
      <article class="metric-card metric-coral">
        <span>총 마케팅 비용</span>
        <strong data-live-marketing>—</strong>
        <small>광고와 콘텐츠 포함</small>
      </article>
      <article class="metric-card">
        <span>활용한 AI</span>
        <strong data-live-ai>—</strong>
        <small>실제 제작에 사용</small>
      </article>
    </div>
  </section>

  <section class="section shell projects-section">
    <div class="section-heading row-heading">
      <div><span class="eyebrow">SELECTED WORK</span><h2>최근 프로젝트</h2></div>
      <a class="text-link" href="/projects">전체 프로젝트 <span>↗</span></a>
    </div>
    <div class="projects-grid" data-live-project-list>
      {[0, 1, 2].map((index) => (
        <article class={`project-card skeleton-card${index === 0 ? ' project-card-featured' : ''}`} aria-hidden="true">
          <div class="project-visual"></div>
          <div class="project-card-body">
            <span class="skeleton-block" style="width:38%;height:24px"></span>
            <span class="skeleton-block" style="width:85%;height:15px;margin-top:16px"></span>
            <span class="skeleton-block" style="width:60%;height:15px;margin-top:8px"></span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section shell results-section">
    <div class="results-intro">
      <span class="eyebrow">HONEST RESULTS</span>
      <h2>성공도 실패도<br />전부 자산이니까.</h2>
      <p>성공은 매출과 반복 사용으로 판단합니다. 실패한 실험도 배운 점과 함께 남깁니다.</p>
      <a class="button button-outline" href="/projects">판단 기준 자세히 보기</a>
    </div>
    <div class="chart-card donut-card">
      <div class="card-label"><span>프로젝트 결과</span><small>완료 프로젝트</small></div>
      <div class="donut-wrap">
        <div class="donut is-loading" data-live-donut style="--success:0deg"><span><b data-live-success>—</b>SUCCESS</span></div>
        <div class="legend">
          <p><i class="dot dot-blue"></i><span>성공</span><b data-live-success>—</b></p>
          <p><i class="dot dot-coral"></i><span>실패</span><b data-live-failure>—</b></p>
        </div>
      </div>
    </div>
    <div class="chart-card bars-card">
      <div class="card-label"><span>연도별 프로젝트</span><small>누적 기록</small></div>
      <div class="bars">
        {yearData.map((item) => (
          <div class="bar-item" data-current-year={item.year === '2026' ? 'true' : undefined}>
            <span class="bar-count" data-year-count={item.year === '2026' ? 'true' : undefined}>{item.count ?? '—'}</span>
            <div class="bar" data-year-bar={item.year === '2026' ? 'true' : undefined} style={`height:${30 + (item.count ?? 0) * 10}px`}></div>
            <small>{item.year}</small>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section shell journal-section">
    <div class="section-heading row-heading">
      <div><span class="eyebrow">BUILD JOURNAL</span><h2>만들며 배운 것들</h2></div>
      <a class="text-link" href="/blog">모든 글 보기 <span>↗</span></a>
    </div>
    <div class="post-list" data-live-post-list>
      {[0, 1, 2].map(() => (
        <div class="post-row" aria-hidden="true">
          <span class="skeleton-block" style="width:32px;height:20px"></span>
          <div>
            <span class="skeleton-block" style="width:150px;height:12px"></span>
            <span class="skeleton-block" style="width:70%;height:26px;margin-top:12px"></span>
          </div>
          <span class="skeleton-block" style="width:85%;height:15px"></span>
          <span></span>
        </div>
      ))}
    </div>
  </section>

  <section class="section shell message-section">
    <div class="message-copy">
      <span class="eyebrow">CHEER ME ON</span>
      <h2>혼자 만들지만,<br />혼자는 아니니까.</h2>
      <p>작은 한마디가 다음 프로젝트를 출시하게 만듭니다.</p>
      <a class="button button-primary" href="/messages">응원 메시지 남기기 <span>♡</span></a>
    </div>
    <div class="message-stack" data-live-message-list>
      {[0, 1, 2].map((index) => (
        <blockquote class="skeleton-note" style={`--rotate:${index % 2 ? '1.5deg' : '-1deg'}`} aria-hidden="true">
          <span>“</span>
          <p><span class="skeleton-block" style="width:100%;height:14px"></span><span class="skeleton-block" style="width:70%;height:14px;margin-top:9px"></span></p>
          <footer><span class="skeleton-block" style="width:60px;height:11px"></span></footer>
        </blockquote>
      ))}
    </div>
  </section>
  <script>
    import { createMessageNote, createPostRow, createProjectCard } from '../lib/content-ui';
    import {
      cacheList,
      cacheProject,
      fetchPublicMessages,
      fetchPublicPosts,
      fetchPublicProjects,
      readCachedList
    } from '../lib/public-data';

    const won = new Intl.NumberFormat('ko-KR');

    const showNotice = (selector: string, message: string) => {
      const notice = document.createElement('p');
      notice.className = 'list-empty';
      notice.textContent = message;
      document.querySelector(selector)?.replaceChildren(notice);
    };

    const renderProjects = (liveProjects: any[]) => {
      document.querySelector('[data-live-project-list]')?.replaceChildren(
        ...liveProjects.slice(0, 3).map((project, index) => createProjectCard(project, index, index === 0))
      );
      const completed = liveProjects.filter((project) => ['successful', 'closed'].includes(project.status));
      const successful = completed.filter((project) => project.status === 'successful').length;
      const successRate = completed.length ? Math.round(successful / completed.length * 100) : 0;
      const durations = liveProjects
        .filter((project) => project.started_at && project.launched_at)
        .map((project) => Math.max(1, Math.round((new Date(project.launched_at).getTime() - new Date(project.started_at).getTime()) / 86400000)));
      const averageDays = durations.length ? Math.round(durations.reduce((sum, days) => sum + days, 0) / durations.length) : 0;
      const tools = new Set<string>();
      liveProjects.forEach((project: any) => project.project_ai_tools?.forEach((link: any) => {
        if (link.ai_tools?.name) tools.add(link.ai_tools.name);
      }));
      const revenue = liveProjects.reduce((sum, project) => sum + Number(project.revenue || 0), 0);
      const marketing = liveProjects.reduce((sum, project) => sum + Number(project.marketing_cost || 0), 0);

      document.querySelectorAll('[data-live-success]').forEach((node) => node.textContent = `${successRate}%`);
      const failureRate = completed.length ? 100 - successRate : 0;
      document.querySelectorAll('[data-live-failure]').forEach((node) => node.textContent = `${failureRate}%`);
      const donut = document.querySelector<HTMLElement>('[data-live-donut]');
      donut?.style.setProperty('--success', `${successRate * 3.6}deg`);
      donut?.classList.remove('is-loading');
      document.querySelector('[data-live-revenue]')!.textContent = `₩${won.format(revenue)}`;
      document.querySelector('[data-live-projects]')!.textContent = String(liveProjects.length).padStart(2, '0');
      document.querySelector('[data-live-days]')!.textContent = String(averageDays);
      document.querySelector('[data-live-marketing]')!.textContent = `₩${won.format(marketing)}`;
      document.querySelector('[data-live-ai]')!.textContent = String(tools.size).padStart(2, '0');
      document.querySelector('[data-year-count]')!.textContent = String(liveProjects.length);
      document.querySelector<HTMLElement>('[data-year-bar]')?.style.setProperty('height', `${30 + liveProjects.length * 10}px`);
    };

    const renderPosts = (livePosts: any[]) => {
      document.querySelector('[data-live-post-list]')?.replaceChildren(
        ...livePosts.slice(0, 3).map((post, index) => createPostRow(post, index))
      );
    };

    const renderMessages = (liveMessages: any[]) => {
      document.querySelector('[data-live-message-list]')?.replaceChildren(
        ...liveMessages.slice(0, 3).map((message, index) => createMessageNote(message, index))
      );
    };

    const cachedProjects = readCachedList('projects');
    if (cachedProjects?.length) renderProjects(cachedProjects);
    const cachedPosts = readCachedList('posts');
    if (cachedPosts?.length) renderPosts(cachedPosts);
    const cachedMessages = readCachedList('messages');
    if (cachedMessages?.length) renderMessages(cachedMessages);

    const [liveProjects, livePosts, liveMessages] = await Promise.all([
      fetchPublicProjects().catch(() => null),
      fetchPublicPosts(3).catch(() => null),
      fetchPublicMessages(3).catch(() => null)
    ]);

    if (liveProjects?.length) {
      liveProjects.forEach(cacheProject);
      cacheList('projects', liveProjects);
      renderProjects(liveProjects);
    } else if (!cachedProjects?.length) {
      showNotice('[data-live-project-list]', liveProjects ? '아직 공개된 프로젝트가 없습니다.' : '프로젝트를 불러오지 못했습니다.');
    }

    if (livePosts?.length) {
      cacheList('posts', livePosts);
      renderPosts(livePosts);
    } else if (!cachedPosts?.length) {
      showNotice('[data-live-post-list]', livePosts ? '아직 공개된 글이 없습니다.' : '글을 불러오지 못했습니다.');
    }

    if (liveMessages?.length) {
      cacheList('messages', liveMessages);
      renderMessages(liveMessages);
    } else if (!cachedMessages?.length) {
      showNotice('[data-live-message-list]', liveMessages ? '첫 번째 응원 메시지를 남겨주세요 ♡' : '메시지를 불러오지 못했습니다.');
    }
  </script>
</BaseLayout>
