---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="응원 메시지 — JAE STUDIO" description="Jae의 다음 프로젝트에 응원 한마디를 남겨주세요.">
  <section class="message-page shell">
    <div class="message-form-copy">
      <span class="eyebrow">LEAVE A NOTE</span>
      <h1>다음 출시를 위한<br /><em>작은 한마디.</em></h1>
      <p>남겨주신 메시지는 확인 후 이 페이지와 첫 화면에 공개됩니다.</p>
      <form class="message-form" id="message-form">
        <label>이름 또는 닉네임<input name="name" maxlength="30" placeholder="어떻게 불러드릴까요?" required /></label>
        <label>응원 메시지<textarea name="message" maxlength="300" rows="5" placeholder="Jae에게 힘이 되는 한마디를 남겨주세요." required></textarea></label>
        <div class="form-footer"><small>최대 300자 · 관리자 승인 후 공개</small><button class="button button-primary" type="submit">메시지 보내기 <span>♡</span></button></div>
        <p class="form-status" aria-live="polite"></p>
      </form>
    </div>
    <div class="message-wall" data-message-wall>
      {[0, 1, 2].map((index) => (
        <blockquote class="skeleton-note" style={`--rotate:${index % 3 === 0 ? '-1.5deg' : index % 3 === 1 ? '1deg' : '-.4deg'}`} aria-hidden="true">
          <span>“</span>
          <p><span class="skeleton-block" style="width:100%;height:14px"></span><span class="skeleton-block" style="width:70%;height:14px;margin-top:9px"></span></p>
          <footer><span class="skeleton-block" style="width:60px;height:11px"></span></footer>
        </blockquote>
      ))}
    </div>
  </section>
  <script>
    import { supabase } from '../lib/supabase';
    import { createMessageNote } from '../lib/content-ui';

    const form = document.querySelector<HTMLFormElement>('#message-form');
    const status = document.querySelector<HTMLElement>('.form-status');
    const { data: approvedMessages, error: loadError } = await supabase
      .from('support_messages')
      .select('id,display_name,message,created_at')
      .eq('is_approved', true)
      .order('created_at', { ascending: false });

    if (approvedMessages?.length) {
      document.querySelector('[data-message-wall]')?.replaceChildren(
        ...approvedMessages.map((message, index) => createMessageNote(message, index))
      );
    } else {
      const notice = document.createElement('p');
      notice.className = 'list-empty';
      notice.textContent = loadError ? '메시지를 불러오지 못했습니다.' : '아직 공개된 메시지가 없습니다. 첫 번째 응원을 남겨주세요 ♡';
      document.querySelector('[data-message-wall]')?.replaceChildren(notice);
    }
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const formData = new FormData(form);
      const displayName = String(formData.get('name') || '').trim();
      const message = String(formData.get('message') || '').trim();

      if (!displayName || !message) return;
      if (submitButton) submitButton.disabled = true;
      if (status) status.textContent = '메시지를 보내고 있어요…';

      const { error } = await supabase.from('support_messages').insert({
        display_name: displayName,
        message,
        is_approved: false
      });

      if (error) {
        if (status) status.textContent = '전송하지 못했습니다. 잠시 후 다시 시도해주세요.';
        console.error('Support message submission failed:', error.message);
      } else {
        if (status) status.textContent = '고맙습니다! 확인 후 응원 메시지에 공개할게요.';
        form.reset();
      }
      if (submitButton) submitButton.disabled = false;
    });
  </script>
</BaseLayout>
