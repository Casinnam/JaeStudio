---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="블로그 — JAE STUDIO" description="혼자 제품을 만들며 배우고 실패한 기록입니다.">
  <section class="page-hero shell compact-hero">
    <span class="eyebrow">BUILD JOURNAL</span>
    <h1>결과보다 생생한<br /><em>과정의 기록.</em></h1>
    <p>아이디어, 제작, 출시, 첫 결제 그리고 실패까지 솔직하게 씁니다.</p>
  </section>
  <section class="section shell journal-page">
    <div class="post-list" data-post-list>
      {[0, 1, 2].map(() => (
        <div class="post-row" aria-hidden="true">
          <span class="skeleton-block" style="width:32px;height:20px"></span>
          <div>
            <span class="skeleton-block" style="width:150px;height:12px"></span>
            <span class="skeleton-block" style="width:70%;height:26px;margin-top:12px"></span>
          </div>
          <span class="skeleton-block" style="width:85%;height:15px"></span>
          <span></span>
        </div>
      ))}
    </div>
  </section>
  <script>
    import { createPostRow } from '../../lib/content-ui';
    import { cacheList, fetchPublicPosts, readCachedList } from '../../lib/public-data';

    const list = document.querySelector('[data-post-list]');
    const render = (posts: any[]) =>
      list?.replaceChildren(...posts.map((post, index) => createPostRow(post, index)));
    const showNotice = (message: string) => {
      const notice = document.createElement('p');
      notice.className = 'list-empty';
      notice.textContent = message;
      list?.replaceChildren(notice);
    };

    const cached = readCachedList('posts');
    if (cached?.length) render(cached);

    try {
      const data = await fetchPublicPosts();
      if (data?.length) {
        cacheList('posts', data);
        render(data);
      } else if (!cached?.length) {
        showNotice('아직 공개된 글이 없습니다.');
      }
    } catch {
      if (!cached?.length) showNotice('글을 불러오지 못했습니다. 잠시 후 다시 시도해주세요.');
    }
  </script>
</BaseLayout>
